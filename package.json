{
  "name": "performance-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{json,md,mjs,ts}\"",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx node_modules/typeorm/cli.js migration:run -d src/lib/db/data-source.ts",
    "db:revert": "tsx node_modules/typeorm/cli.js migration:revert -d src/lib/db/data-source.ts",
    "db:show": "tsx node_modules/typeorm/cli.js migration:show -d src/lib/db/data-source.ts",
    "db:generate": "tsx node_modules/typeorm/cli.js migration:generate -d src/lib/db/data-source.ts",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:clear": "tsx src/lib/db/clear.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.468.0",
    "next": "16.2.10",
    "nodemailer": "9.0.3",
    "pg": "^8.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.57.0",
    "recharts": "^2.15.3",
    "reflect-metadata": "^0.2.2",
    "server-only": "^0.0.1",
    "typeorm": "^0.3.24",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.32",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.29.0",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.10",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
